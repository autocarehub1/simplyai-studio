{
  "name": "05 — Closed Won Onboarding + Review Request",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "closed-won",
        "responseMode": "responseNode"
      },
      "id": "webhook",
      "name": "Webhook — Closed Won",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
